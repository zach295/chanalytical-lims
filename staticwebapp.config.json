{
  "routes": [
    { "route": "/api/*", "allowedRoles": ["anonymous"] },
    { "route": "/admin-dashboard.html", "allowedRoles": ["anonymous"] },
    { "route": "/*", "serve": "/index.html", "statusCode": 200 }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "*.html", "*.js", "*.css", "*.png", "*.json", "*.ico"]
  },
  "mimeTypes": {
    ".json": "application/json"
  }
}
